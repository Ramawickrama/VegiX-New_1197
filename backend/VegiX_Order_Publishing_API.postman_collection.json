    {
      "name": "Farmer Orders",
      "item": [
        {
          "name": "Publish Selling Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer <FARMER_TOKEN>"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vegetableId\": \"<VEGETABLE_ID>\",\n  \"quantity\": 100,\n  \"unit\": \"kg\",\n  \"pricePerUnit\": 150,\n  \"location\": \"Colombo\",\n  \"quality\": \"premium\",\n  \"description\": \"Fresh organic tomatoes from my farm\",\n  \"deliveryDate\": \"2026-02-28\"\n}"
            },
