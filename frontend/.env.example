# ─── VegiX Frontend — Environment Variables ──────────────────────────────────
# Copy this file to .env and adjust for your environment. NEVER commit .env to git!

# NOTE: VITE_API_URL is NOT used in production
# API baseURL is hardcoded as '/api' - nginx proxies /api/* to backend

# LOCAL DEVELOPMENT with direct backend access:
# VITE_API_URL=http://localhost:5000
